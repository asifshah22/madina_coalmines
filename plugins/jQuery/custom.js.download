function getDivisionOptionByProvinceNRegionsOption(province,region,tkn,ckie,ddlid,s_id){
    var abc = tkn;
    var def = $.cookie(ckie);
    var hml = '<option value="">Select Division</option>';
    s_id = (s_id == undefined) ? 0 : s_id
    var dt = {"province" : province,"region" : region,csrf_test_name:def, value:def}
    $.ajax({
        type: "POST",
        url: site_url+"/admin/globals/getDivisionByProvinceNRegion.html",
        data : dt,
        dataType : "JSON"
     }).done(function( msg ) {
        if(msg.status == true){
            var data = msg.data
            $(data).each(function(key,val){
                var select ='';
                if(s_id == val.ID){
                    select = "selected='selected'"
                }
                hml += '<option value="'+val.ID+'" '+select+'>'+val.DIVISION+'</option>';
            })
            $('#'+ddlid).html(hml);
        }
    });
}

