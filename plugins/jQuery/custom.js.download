 function addCommas(inputText) {
    // pattern works from right to left
    var commaPattern = /(\d+)(\d{3})(\.\d*)*$/;
    var callback = function (match, p1, p2, p3) {
        return p1.replace(commaPattern, callback) + ',' + p2 + (p3 || '');
    };
    return inputText.replace(commaPattern, callback);
}

// events for demo
$('.amt').live('blur',function(){
    var amt = $(this).val()
    $(this).val(addCommas(amt));
});

 function removeCommas(inputText) {
    // pattern works from right to left
    str =inputText.replace(",","");
    return str;
}

//$('#applicant_issuance_register').live('change',function(){
function appRegInfo(dt, def ){    
    s_id = dt;
    var result ;
    var dt = {csrf_test_name:def, value:def};
    $.ajax({
        type: "POST",
        url: site_url+"/admin/register/getApplicantIssueRegisterInfo/"+s_id+".html",
        data : dt,
        dataType : "JSON"
     }).done(function( response ) {        
        result =response;
        if(result.status == true){
            $('#cnic').val(result.dt.cnic)
            $('#province').val(result.dt.provinceId)
            $('#district').val(result.dt.district)
            $('#name').val(result.dt.name)
        }else{
            $('#cnic').val('')
            $('#province').val('')
            $('#district').val('')
            $('#name').val('')
        }
    });
     return result;
 }
//});
